# =============================================================================
# Sub2API 主服务器环境变量 (Master Server)
# =============================================================================
# 主服务器运行 Sub2API + PostgreSQL + Redis，子服务器连接到这里。
#
# 使用方法：
#   cp .env.master .env
#   然后修改下面标注 [必改] 的项
# =============================================================================

# -----------------------------------------------------------------------------
# [必改] 数据库密码
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=请替换为安全密码

# -----------------------------------------------------------------------------
# [必改] 管理员账号
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@qq.com
ADMIN_PASSWORD=请替换为管理员密码

# -----------------------------------------------------------------------------
# [必改] 密钥（用 openssl rand -hex 32 生成，所有服务器必须一致）
# -----------------------------------------------------------------------------
JWT_SECRET=请替换为openssl_rand_hex_32生成的值
TOTP_ENCRYPTION_KEY=请替换为openssl_rand_hex_32生成的值

# -----------------------------------------------------------------------------
# 服务器配置（一般不用改）
# -----------------------------------------------------------------------------
BIND_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Shanghai

# -----------------------------------------------------------------------------
# 性能优化（8000+ 账号分布式部署核心配置）
# -----------------------------------------------------------------------------
# 本地缓存 TTL（秒）：子服务器在此时间内不访问 Redis
GATEWAY_SCHEDULING_LOCAL_SNAPSHOT_CACHE_TTL_SECONDS=3
# 快照读取上限：从 Redis 最多拉多少个账号（减少网络传输）
GATEWAY_SCHEDULING_SNAPSHOT_READ_LIMIT=500
# 候选上限：负载查询前按优先级预筛（减少 Redis 命令数）
GATEWAY_SCHEDULING_MAX_CANDIDATES_FOR_LOAD_QUERY=100
# Leader 选举：多实例只有 1 个执行后台轮询/重建
GATEWAY_SCHEDULING_LEADER_ELECTION_ENABLED=true
# Outbox 轮询间隔（秒）
GATEWAY_SCHEDULING_OUTBOX_POLL_INTERVAL_SECONDS=3

# -----------------------------------------------------------------------------
# 日志配置（防止磁盘爆满）
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_SAMPLING_ENABLED=true
LOG_SAMPLING_INITIAL=5
LOG_SAMPLING_THEREAFTER=200
LOG_ROTATION_MAX_SIZE_MB=50
LOG_ROTATION_MAX_BACKUPS=3
LOG_ROTATION_MAX_AGE_DAYS=3

# -----------------------------------------------------------------------------
# 连接池（大规模部署可调整）
# -----------------------------------------------------------------------------
DATABASE_MAX_OPEN_CONNS=256
DATABASE_MAX_IDLE_CONNS=128
REDIS_POOL_SIZE=4096
REDIS_MIN_IDLE_CONNS=256

# -----------------------------------------------------------------------------
# Redis 密码（留空表示无密码，生产环境建议设置）
# -----------------------------------------------------------------------------
REDIS_PASSWORD=
