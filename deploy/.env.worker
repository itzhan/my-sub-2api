# =============================================================================
# Sub2API 子服务器环境变量 (Worker Server)
# =============================================================================
# 子服务器只运行 Sub2API，连接主服务器的 PostgreSQL 和 Redis。
#
# 使用方法：
#   cp .env.worker .env
#   然后修改下面标注 [必改] 的项
# =============================================================================

# -----------------------------------------------------------------------------
# [必改] 主服务器地址
# -----------------------------------------------------------------------------
DATABASE_HOST=主服务器IP
REDIS_HOST=主服务器IP

# -----------------------------------------------------------------------------
# [必改] 数据库密码（和主服务器一致）
# -----------------------------------------------------------------------------
DATABASE_PASSWORD=和主服务器POSTGRES_PASSWORD一致

# -----------------------------------------------------------------------------
# [必改] 管理员账号（和主服务器一致）
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@qq.com
ADMIN_PASSWORD=和主服务器一致

# -----------------------------------------------------------------------------
# [必改] 密钥（必须和主服务器完全一致，否则登录/2FA 失效）
# -----------------------------------------------------------------------------
JWT_SECRET=和主服务器一致
TOTP_ENCRYPTION_KEY=和主服务器一致

# -----------------------------------------------------------------------------
# 服务器配置（一般不用改）
# -----------------------------------------------------------------------------
BIND_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Shanghai

# -----------------------------------------------------------------------------
# 主服务器连接配置（一般不用改）
# -----------------------------------------------------------------------------
DATABASE_PORT=5478
DATABASE_USER=sub2api
DATABASE_DBNAME=sub2api
REDIS_PORT=6378
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# 性能优化（和主服务器保持一致）
# -----------------------------------------------------------------------------
GATEWAY_SCHEDULING_LOCAL_SNAPSHOT_CACHE_TTL_SECONDS=3
GATEWAY_SCHEDULING_SNAPSHOT_READ_LIMIT=500
GATEWAY_SCHEDULING_MAX_CANDIDATES_FOR_LOAD_QUERY=100
GATEWAY_SCHEDULING_LEADER_ELECTION_ENABLED=true
GATEWAY_SCHEDULING_OUTBOX_POLL_INTERVAL_SECONDS=3

# -----------------------------------------------------------------------------
# 日志配置（和主服务器保持一致）
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_SAMPLING_ENABLED=true
LOG_SAMPLING_INITIAL=5
LOG_SAMPLING_THEREAFTER=200
LOG_ROTATION_MAX_SIZE_MB=50
LOG_ROTATION_MAX_BACKUPS=3
LOG_ROTATION_MAX_AGE_DAYS=3

# -----------------------------------------------------------------------------
# 连接池
# -----------------------------------------------------------------------------
DATABASE_MAX_OPEN_CONNS=256
DATABASE_MAX_IDLE_CONNS=128
REDIS_POOL_SIZE=4096
REDIS_MIN_IDLE_CONNS=256
